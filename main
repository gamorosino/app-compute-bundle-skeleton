#!/bin/bash
set -euo pipefail

CONFIG="${CONFIG:-config.json}"
[ -f "$CONFIG" ] || { echo "ERROR: Missing config.json: $CONFIG" >&2; exit 1; }

# Parse config with python and emit shell-safe CLI args.
ARGS="$(
python3 - "$CONFIG" <<'PY'
import json
import shlex
import sys
from pathlib import Path

config_path = Path(sys.argv[1])

with open(config_path, "r") as f:
    cfg = json.load(f)

# Required paths
tck = cfg.get("tck")
t1 = cfg.get("t1")

if not tck or not Path(tck).exists():
    raise SystemExit(f"ERROR: config['tck'] missing or not found: {tck}")
if not t1 or not Path(t1).exists():
    raise SystemExit(f"ERROR: config['t1'] missing or not found: {t1}")

# Output path (force Brainlife datatype layout)
out_default = "track/track.tck"
track_out = cfg.get("track_out", out_default)
track_out = str(Path("track") / Path(track_out).name)

# Optional params (mirror shell defaults)
perc = cfg.get("perc", None)
smooth_density = bool(cfg.get("smooth_density", False))
length_thr = float(cfg.get("length_thr", 0.90))
N_points = int(cfg.get("N_points", 32))
keep_endpoints = bool(cfg.get("keep_endpoints", False))
average_type = cfg.get("average_type", "mean")
endpoint_mode = cfg.get("endpoint_mode", "median")
representative = bool(cfg.get("representative", False))
spline_smooth = cfg.get("spline_smooth", None)

# Basic validation
if N_points < 2:
    raise SystemExit("ERROR: N_points must be >= 2")
if average_type not in {"mean", "median"}:
    raise SystemExit(f"ERROR: average_type must be 'mean' or 'median'. Got: {average_type}")
if endpoint_mode not in {"mean", "median", "median_project"}:
    raise SystemExit(
        f"ERROR: endpoint_mode must be 'mean', 'median', or 'median_project'. Got: {endpoint_mode}"
    )

# Ensure output dir exists before container execution
Path("track").mkdir(parents=True, exist_ok=True)

# Build CLI for bundle_skeleton.py
args = [
    "bundle_skeleton.py",
    tck,
    track_out,
    t1,
    "--length-thr", str(length_thr),
    "--n-points", str(N_points),
    "--average-type", average_type,
    "--endpoint-mode", endpoint_mode,
]

if perc is None:
    args += ["--perc", "0"]
else:
    args += ["--perc", str(float(perc))]

args += ["--smooth-density" if smooth_density else "--no-smooth-density"]

if keep_endpoints:
    args += ["--keep-endpoints"]
if representative:
    args += ["--representative"]
if spline_smooth is not None:
    args += ["--spline-smooth", str(float(spline_smooth))]

print(" ".join(shlex.quote(a) for a in args))
PY
)"

echo "Running inside container:"
echo "singularity exec -e docker://gamorosino/tract_align:latest micromamba run -n tract_align python3 $ARGS"

singularity exec -e docker://gamorosino/tract_align:latest \
    micromamba run -n tract_align \
    python3 $ARGS
